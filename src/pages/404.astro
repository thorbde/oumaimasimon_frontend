---
import Button from "../components/Button.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <section id="notfound">
    <p class="number" aria-hidden="true">404</p>
    <h1>Vi hittade inte sidan</h1>
    <p class="lede">
      Länken kanske är gammal, eller så har vi flyttat något. Häng med
      tillbaka till hemsidan.
    </p>
    <Button href="/">Tillbaka till hemsidan</Button>
  </section>
</Layout>

<style>
  #notfound {
    min-height: calc(100vh - var(--header-height));
    padding: 6rem 1.5rem 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    text-align: center;
  }

  .number {
    font-family: var(--font-display);
    font-size: clamp(6rem, 24vw, 11rem);
    line-height: 0.9;
    margin: 0;
    color: color-mix(in srgb, var(--color-primary-500) 35%, transparent);
    letter-spacing: -0.03em;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 6vw, 2.5rem);
    line-height: 1.1;
    margin: 0;
  }

  .lede {
    max-width: 28rem;
    color: color-mix(in srgb, var(--color-primary-900) 75%, transparent);
    margin: 0 0 0.5rem;
  }

  @media (min-width: 768px) {
    #notfound {
      padding: 8rem 3rem 6rem;
    }
  }
</style>
